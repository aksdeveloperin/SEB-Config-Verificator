{
  "manifest_version": 3,
  "name": "Manual Session Tool",
  "version": "1.0",

  "permissions": [
    "cookies",
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "https://*.iitp.ac.in/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html"
  },

  "commands": {
    "start-action": {
      "suggested_key": {
        "default": "Ctrl+Shift+U"
      },
      "description": "Start Exam Helper"
    }
  }
}