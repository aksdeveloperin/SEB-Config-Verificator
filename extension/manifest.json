{
  "manifest_version": 3,
  "name": "SEB Config Verificator",
  "version": "1.9.2",
  "description": "Verifies Safe Exam Browser (SEB) configuration integrity in controlled exam environments.",

  "permissions": [
    "cookies",
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "https://*.iitp.ac.in/*"
  ],

  "action": {
    "default_popup": "popup.html"
  },

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}